# ======================
# Project Horizons .gitignore
# ======================

# Mod JARs (managed by mod-manifest.json, not tracked in git)
server/mods/*.jar
*.jar

# Server runtime files
server/world/
server/logs/
server/crash-reports/
server/.fabric/
server/.mixin.out/
server/libraries/
server/versions/
server/*.log
server/usercache.json
server/whitelist.json
server/ops.json
server/banned-ips.json
server/banned-players.json
server/eula.txt
server/server.properties

# IDE files
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Build output
build/
dist/
*.zip

# Python
__pycache__/
*.pyc
*.pyo
.env
venv/

# Codebase reference (large, not part of modpack)
codebases/
codebase-zips/

# Reference packs from Modrinth (download locally; GitHub rejects >100MB)
references/*.mrpack

# Portable JDK (install JDK 21 under tools/java locally; do not commit)
tools/java/

# Temporary files
*.tmp
*.bak
*.swp
*~
